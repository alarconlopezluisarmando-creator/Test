def get_bms_ii_file_from_sftp():
    """Download the latest BMS_Progress_Tracker_II file from SSH server."""
    file_pattern_ii = 'BMS_Progress_Tracker_II'
    print(f"Connecting to SSH server for BMS_Progress_Tracker_II...")
    
    # Establish SSH/SFTP connection
    transport = get_ssh_connection()
    sftp = paramiko.SFTPClient.from_transport(transport)
    
    try:
        # List files in the remote directory
        print(f"Listing files in: {SSH_REMOTE_PATH}")
        files = sftp.listdir(SSH_REMOTE_PATH)
        
        # Filter files matching the pattern
        matching_files = [f for f in files if file_pattern_ii in f and f.endswith('.xlsx')]
        print(f"Found {len(matching_files)} files matching pattern '{file_pattern_ii}': {matching_files}")
        
        if not matching_files:
            print(f"No BMS_Progress_Tracker_II files found. Will only use main BMS_TrackerProgress_ file.")
            return None
        
        # Get file stats to find the latest one
        file_stats = []
        for filename in matching_files:
            remote_filepath = os.path.join(SSH_REMOTE_PATH, filename)
            stat = sftp.stat(remote_filepath)
            file_stats.append((filename, stat.st_mtime))
        
        # Sort by modification time (descending) to get the latest
        file_stats.sort(key=lambda x: x[1], reverse=True)
        latest_file = file_stats[0][0]
        latest_file_path = os.path.join(SSH_REMOTE_PATH, latest_file)
        
        print(f"Latest BMS_Progress_Tracker_II file identified: {latest_file} (modified: {datetime.fromtimestamp(file_stats[0][1])})")
        
        # Ensure local directory exists
        os.makedirs(os.path.dirname(LOCAL_FILE_PATH_II), exist_ok=True)
        
        # Download the file
        print(f"Downloading BMS_Progress_Tracker_II to: {LOCAL_FILE_PATH_II}")
        sftp.get(latest_file_path, LOCAL_FILE_PATH_II)
        print(f"BMS_Progress_Tracker_II file downloaded successfully.")
        
        return LOCAL_FILE_PATH_II
        
    finally:
        sftp.close()
        transport.close()
        print("SSH connection closed.")


