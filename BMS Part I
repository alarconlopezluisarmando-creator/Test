# --- Helper functions ---

def sort_columns_by_date(df_pivot):
    """Sorts the columns of a pivot table chronologically, handling both formats."""
    def sort_key(col):
        col_str = col
        if col_str == 'No Date':
            return (9999, 99, 99)
        try:
            if '- Week' in col_str:
                # Handle new format: "December 2024 - January 2025-Week 1"
                # or old format: "December 2024-Week 44"
                parts = col_str.split('- Week')
                week_number = int(parts[1].strip())
                
                # The first part before "- Week" contains the month(s)
                # Format: "December 2024 - January 2025" or "December 2024"
                months_part = parts[0].strip()
                
                # Parse the first month (the start month)
                month_years = months_part.split(' - ')
                first_month_year = month_years[0].strip()
                month_year = datetime.strptime(first_month_year, '%B %Y')
                
                # Sort by the Monday date's month/year, then week number
                return (month_year.year, month_year.month, week_number)
            else:
                month_year = datetime.strptime(col_str, '%B %Y')
                return (month_year.year, month_year.month, 0)
        except (ValueError, IndexError):
            return (9999, 99, 99)

    sorted_cols = sorted(df_pivot.columns, key=sort_key)
    return df_pivot.reindex(columns=sorted_cols)


def generate_complete_date_range_columns(df_unpivoted, date_format='month'):
    """Generate complete date range columns between earliest and latest dates.
    
    Args:
        df_unpivoted: The unpivoted dataframe with Status dates
        date_format: 'month' for monthly columns, 'week' for weekly columns
    
    Returns:
        List of date column names spanning the complete range
    """
    # Get valid dates (exclude NaT)
    valid_dates = df_unpivoted[df_unpivoted['Status'].notna()]['Status']
    
    if len(valid_dates) == 0:
        return []
    
    min_date = valid_dates.min()
    max_date = valid_dates.max()
    
    date_columns = []
    
    if date_format == 'month':
        # Generate all months between min and max dates
        # Use year/month tuples for comparison to ensure all months are included
        current_year = min_date.year
        current_month = min_date.month
        max_year = max_date.year
        max_month = max_date.month
        
        while (current_year < max_year) or (current_year == max_year and current_month <= max_month):
            # Create a date object for the first day of current month
            current_date = datetime(current_year, current_month, 1)
            month_str = current_date.strftime('%B %Y')
            date_columns.append(month_str)
            
            # Move to next month
            if current_month == 12:
                current_month = 1
                current_year += 1
            else:
                current_month += 1
    else:  # week
        # Generate all weeks between min and max dates using ISO week logic
        # Use the Monday of each ISO week for consistent labeling with pivot table
        current_date = min_date
        while current_date <= max_date:
            # Get the Monday (start) of the ISO week for current date
            week_monday = current_date - pd.to_timedelta(current_date.dayofweek, unit='D')
            week_sunday = week_monday + timedelta(days=6)
            week_num = week_monday.isocalendar()[1]
            month_start = week_monday.strftime('%B %Y')
            month_end = week_sunday.strftime('%B %Y')
            
            # Dynamic week label showing both months if week spans across month/year boundary
            if month_start != month_end:
                week_str = f"{month_start} - {month_end}-Week {week_num}"
            else:
                week_str = f"{month_start}-Week {week_num}"
            
            # Only add if not duplicate (can happen when moving across year boundaries)
            if week_str not in date_columns:
                date_columns.append(week_str)
            # Move to next week (from Monday)
            current_date = week_monday + timedelta(weeks=1)
    
    return date_columns


def add_cumulative_rows(df_report):
    """Adds cumulative rows to the report dataframe."""
    original_index_names = df_report.index.names
    cumulative_df = df_report.copy()
    cumulative_df = df_report.cumsum(axis=1)

    cumulative_df.index = pd.MultiIndex.from_tuples(
        [(idx[0] + ' (Cumulative)',) + idx[1:] for idx in cumulative_df.index],
        names=original_index_names
    )
    
    final_df = pd.concat([df_report, cumulative_df])
    return final_df.sort_index(level=['Weekly', 'F/A'], sort_remaining=False)


def add_cumulative_rows_with_custom_name(df_report):
    """Adds cumulative rows to the report dataframe using Custom_Name for grouping."""
    original_index_names = df_report.index.names
    cumulative_df = df_report.copy()
    cumulative_df = df_report.cumsum(axis=1)

    # Create cumulative index with Custom_Name (Cumulative) suffix
    # Index structure: (Custom_Name, F/A, Task_Name, Milestone)
    cumulative_df.index = pd.MultiIndex.from_tuples(
        [(idx[0] + ' (Cumulative)', idx[1], idx[2], idx[3]) for idx in cumulative_df.index],
        names=original_index_names
    )
    
    final_df = pd.concat([df_report, cumulative_df])
    return final_df


def add_cumulative_rows_with_row_id(df_report):
    """Adds cumulative rows to the report dataframe with Row_ID for sorting."""
    original_index_names = df_report.index.names
    cumulative_df = df_report.copy()
    cumulative_df = df_report.cumsum(axis=1)

    # Create cumulative index with Custom_Name (Cumulative) suffix
    # Index structure: (Row_ID, Custom_Name, F/A, Task_Name, Milestone)
    cumulative_df.index = pd.MultiIndex.from_tuples(
        [(idx[0], idx[1] + ' (Cumulative)', idx[2], idx[3], idx[4]) for idx in cumulative_df.index],
        names=original_index_names
    )
    
    final_df = pd.concat([df_report, cumulative_df])
    return final_df


def extract_f_a(milestone_str):
    """Extracts Forecast/Actual indicator from milestone string."""
    match = re.search(r'V:\((F|A)', milestone_str)
    return 'Forecast' if match and match.group(1) == 'F' else 'Actual'


