def format_excel_start_at_b3(file_path):
    """Format Excel file: start at B3, blue header with white text, 70% zoom, week column line breaks, and 150px column width."""
    wb = load_workbook(file_path)
    
    # Define styles
    blue_fill = PatternFill(start_color="0066CC", end_color="0066CC", fill_type="solid")
    white_font = Font(color="FFFFFF", bold=True)
    center_alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
    
    for sheet_name in wb.sheetnames:
        ws = wb[sheet_name]
        
        # Skip the all_bms_g tab as it contains graphs
        if sheet_name == 'all_bms_g':
            continue
        
        # Insert empty row at top (row 1)
        ws.insert_rows(1)
        
        # Insert empty column at left (column A)
        ws.insert_cols(1)
        
        # Format the header row (now row 2 after insertion)
        for cell in ws[2]:
            cell.fill = blue_fill
            cell.font = white_font
            cell.alignment = center_alignment
            
            # Add line breaks to week columns (format: "October 2024 - Week 44" -> "October 2024 -\nWeek 44")
            if cell.value and isinstance(cell.value, str) and ' - Week ' in cell.value:
                cell.value = cell.value.replace(' - Week ', '-\nWeek ')
        
        # Set header row height to accommodate multi-line text
        ws.row_dimensions[2].height = 80
        
        # Set all column widths to approximately 150 pixels (22 character units for Calibri 11pt)
        for col in ws.columns:
            col_letter = col[0].column_letter
            ws.column_dimensions[col_letter].width = 22
        
        # Set zoom to 70%
        ws.sheet_view.zoomScale = 70
    
    wb.save(file_path)
    print(f"Applied B3 formatting with blue header, 70% zoom, and week column line breaks to {file_path}")


def filter_by_bms_group(df_report, bms_group):
    """Filter the report dataframe to include only rows belonging to a specific BMS group.
    
    Args:
        df_report: The weekly report dataframe
        bms_group: The BMS group to filter by (e.g., 'BMS_1', 'BMS_2', etc.)
    
    Returns:
        Filtered dataframe with only the specified BMS group milestones
    """
    # Filter by BMS group - strip "(Cumulative)" suffix for lookup to include cumulative rows
    filtered_df = df_report[df_report['Task Name'].apply(
        lambda x: get_bms_group(x.replace(' (Cumulative)', '')) == bms_group
    )].copy()
    
    # Reset the Weekly category to show for the first row only
    # Extract base task name (without "(Cumulative)" suffix)
    filtered_df['Base_Task_Name'] = filtered_df['Task Name'].str.replace(' (Cumulative)', '', regex=False)
    # Mark first row of each base task name group
    filtered_df['Is_First'] = ~filtered_df.duplicated(subset=['Base_Task_Name'], keep='first')
    # Get category for first rows
    filtered_df['Weekly'] = filtered_df.apply(
        lambda row: get_category(row['Base_Task_Name']) if row['Is_First'] else '', 
        axis=1
    )
    # Drop helper columns
    filtered_df = filtered_df.drop(columns=['Base_Task_Name', 'Is_First'])
    
    return filtered_df


