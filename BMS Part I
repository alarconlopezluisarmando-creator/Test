def get_milestone_info(milestone_str):
    """Extract milestone info from the MILESTONE_MAPPING."""
    # Try exact match first
    if milestone_str in MILESTONE_LOOKUP:
        return MILESTONE_LOOKUP[milestone_str]
    
    # Try to extract info from the milestone string
    fa = 'Forecast' if '(F ' in milestone_str or '(F)' in milestone_str else 'Actual'
    
    # Extract task name
    match = re.search(r'V:\((?:F|A)(?: \d+)?\) (.+)', milestone_str)
    if match:
        task_name = match.group(1).strip()
    else:
        task_name = milestone_str
    
    # Return default values if not found in mapping
    return {
        'row_id': 999,
        'task_name': task_name,
        'fa': fa,
        'custom_name': task_name,
        'milestone': milestone_str
    }


