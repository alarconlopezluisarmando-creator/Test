def inject_data_to_template(df, sheet_name, target_file):
    """Surgically injects data into the template starting at B3."""
    # Load with data_only=False to keep formulas/charts alive
    wb = load_workbook(target_file, data_only=False) 
    
    if sheet_name not in wb.sheetnames:
        ws = wb.create_sheet(sheet_name)
    else:
        ws = wb[sheet_name]

    # CLEANING STEP: Only clear the specific data range B3:Z500 
    # to avoid touching the Chart XML objects
    for row in ws.iter_rows(min_row=3, max_row=500, min_col=2, max_col=26):
        for cell in row:
            cell.value = None

    # INJECTION STEP:
    # We use a simple loop instead of dataframe_to_rows to be as gentle as possible
    data_values = df.values.tolist()
    for r_idx, row_data in enumerate(data_values, start=3):
        for c_idx, value in enumerate(row_data, start=2):
            # Convert numpy/nan types to standard python types for Excel safety
            if pd.isna(value):
                ws.cell(row=r_idx, column=c_idx).value = None
            else:
                ws.cell(row=r_idx, column=c_idx).value = value
    
    wb.save(target_file)
    wb.close() # Always close to release the file handle
