def inject_data_to_template(df, sheet_name, target_file):
    """Surgically injects data into the template starting at B3."""
    wb = load_workbook(target_file)
    if sheet_name not in wb.sheetnames:
        ws = wb.create_sheet(sheet_name)
    else:
        ws = wb[sheet_name]

    # Clean only the data area (B3 downwards)
    for row in ws.iter_rows(min_row=3, min_col=2):
        for cell in row:
            cell.value = None

    # Inject data starting at Row 3, Column 2 (B3)
    for r_idx, row in enumerate(dataframe_to_rows(df, index=False, header=False), 3):
        for c_idx, value in enumerate(row, 2):
            ws.cell(row=r_idx, column=c_idx, value=value)
    
    wb.save(target_file)

