def safe_inject_to_template(df, sheet_name, target_file):
    """
    Surgically places data into the template without touching 
    the 'Drawing' layer (graphs/shapes).
    """
    # Load with data_only=False to keep the charts alive
    wb = load_workbook(target_file, data_only=False)
    
    if sheet_name not in wb.sheetnames:
        return # Skip if the tab is missing to avoid corruption
    
    ws = wb[sheet_name]

    # Convert DataFrame to a list of lists (excluding headers)
    # We do NOT use dataframe_to_rows here as it can be too 'heavy'
    data_to_insert = df.values.tolist()

    # LOOP ONLY OVER THE DATA: 
    # This starts at Row 3, Column 2 (B3) and stops exactly where the data ends.
    # By NOT looping over the whole sheet, we don't 'bump into' the chart objects.
    for r_idx, row_data in enumerate(data_to_insert, start=3):
        for c_idx, value in enumerate(row_data, start=2):
            # Write only the value, preserving the cell's existing style/anchor
            if pd.isna(value):
                ws.cell(row=r_idx, column=c_idx).value = None
            else:
                ws.cell(row=r_idx, column=c_idx).value = value

    wb.save(target_file)
    wb.close()



