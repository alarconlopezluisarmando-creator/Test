def generate_milestone_charts(**context):
    """Generate milestone charts from the monthly report data."""
    print("=" * 60)
    print("Generating Milestone Charts")
    print("=" * 60)
    
    # Get the generated Excel file path
    excel_file_path = context['task_instance'].xcom_pull(task_ids='generate_bms_report')
    print(f"Reading report from: {excel_file_path}")
    
    # Read the monthly report sheet
    # Due to B3 formatting, row 0 contains the actual headers
    df_monthly = pd.read_excel(excel_file_path, sheet_name='All_BMS_M', header=0)
    print(f"Loaded monthly report: {len(df_monthly)} rows, {len(df_monthly.columns)} columns")
    print(f"Columns: {df_monthly.columns.tolist()[:10]}...")
    
    # Identify column indices:
    # Based on B3 formatting: Col 0=empty, Col 1='Weekly', Col 2='Milestone', 
    # Col 3='F/A', Col 4='Task Name', then date columns
    if len(df_monthly.columns) < 5:
        print("Error: Not enough columns in the monthly report")
        return []
    
    # Get column names by position
    col_weekly = df_monthly.columns[1]
    col_milestone = df_monthly.columns[2]
    col_fa = df_monthly.columns[3]
    col_task_name = df_monthly.columns[4]
    
    print(f"Identified columns:")
    print(f"  Weekly: {col_weekly}")
    print(f"  Milestone: {col_milestone}")
    print(f"  F/A: {col_fa}")
    print(f"  Task Name: {col_task_name}")
    
    generated_charts = []
    
    for chart_config in CHART_CONFIG:
        task_name = chart_config['task_name']
        print(f"\nProcessing chart: {task_name}")
        
        # Filter data for this task name using the identified column
        task_data = df_monthly[
            df_monthly[col_task_name].str.contains(task_name, na=False)
        ]
        
        if len(task_data) == 0:
            print(f"  Warning: No data found for task '{task_name}', skipping...")
            continue
        
        # Get the date columns
        date_columns = [col for col in chart_config['columns'] if col in df_monthly.columns]
        
        if len(date_columns) == 0:
            print(f"  Warning: No matching date columns found, skipping...")
            continue
        
        print(f"  Date columns: {date_columns}")
        print(f"  Found {len(task_data)} rows for this task")
        
        # Extract data for each series
        data_series = {}
        for series_name in chart_config['primary_series'] + chart_config['secondary_series']:
            # Filter by F/A type and cumulative status
            is_cumulative = 'Cumulative' in series_name
            fa_type = series_name.replace(' Cumulative', '')
            
            series_data = task_data[
                (task_data[col_fa] == fa_type) &
                (task_data[col_task_name].str.contains('Cumulative', na=False) == is_cumulative)
            ]
            
            if len(series_data) > 0:
                data_series[series_name] = series_data[date_columns].values[0]
                print(f"  {series_name}: {len(data_series[series_name])} data points")
            else:
                print(f"  Warning: No data found for series '{series_name}'")
                data_series[series_name] = [0] * len(date_columns)
        
        # Create the chart with secondary y-axis for cumulative data
        fig, ax1 = plt.subplots(figsize=(14, 7))
        
        x = range(len(date_columns))
        
        # Primary Y-axis (left) - for non-cumulative data
        color1 = 'tab:blue'
        ax1.set_xlabel('Month', fontsize=12, fontweight='bold')
        ax1.set_ylabel('Monthly Milestones', color=color1, fontsize=12, fontweight='bold')
        
        for i, series_name in enumerate(chart_config['primary_series']):
            if series_name in data_series:
                color = 'tab:blue' if i == 0 else 'tab:green'
                marker = 'o' if i == 0 else '^'
                ax1.plot(x, data_series[series_name], label=series_name, 
                        marker=marker, color=color, linewidth=2.5, markersize=8)
        
        ax1.tick_params(axis='y', labelcolor=color1, labelsize=10)
        ax1.grid(True, alpha=0.3, linestyle='--')
        ax1.set_ylim(bottom=0)
        
        # Secondary Y-axis (right) - for cumulative data
        ax2 = ax1.twinx()
        color2 = 'tab:red'
        ax2.set_ylabel('Cumulative Milestones', color=color2, fontsize=12, fontweight='bold')
        
        for i, series_name in enumerate(chart_config['secondary_series']):
            if series_name in data_series:
                color = 'tab:red' if i == 0 else 'tab:orange'
                marker = 's' if i == 0 else 'd'
                ax2.plot(x, data_series[series_name], label=series_name,
                        marker=marker, color=color, linewidth=2.5, linestyle='--', markersize=8)
        
        ax2.tick_params(axis='y', labelcolor=color2, labelsize=10)
        ax2.set_ylim(bottom=0)
        
        # Set x-axis labels with rotation
        plt.xticks(x, date_columns, rotation=45, ha='right', fontsize=10)
        
        # Title
        title = chart_config.get('title', task_name)
        plt.title(title, fontsize=16, fontweight='bold', pad=20)
        
        # Combine legends from both axes
        lines1, labels1 = ax1.get_legend_handles_labels()
        lines2, labels2 = ax2.get_legend_handles_labels()
        ax1.legend(lines1 + lines2, labels1 + labels2, 
                  fontsize=11, loc='best', framealpha=0.9)
        
        plt.tight_layout()
        
        # Save chart
        output_path = os.path.join(CHARTS_OUTPUT_DIR, chart_config['output_file'])
        plt.savefig(output_path, dpi=300, bbox_inches='tight', facecolor='white')
        plt.close()
        
        print(f"  Chart saved: {output_path}")
        generated_charts.append(output_path)
    
    print(f"\n{'=' * 60}")
    print(f"Successfully generated {len(generated_charts)} charts")
    print(f"{'=' * 60}")
    
    return generated_charts


