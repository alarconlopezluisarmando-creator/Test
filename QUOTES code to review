def handle_duplicate_quotes_with_priority_mapping(df_diff):
    """
    Handle ALL duplicate QT:Quote ID by applying priority mapping for Doc Review Status Text.
    Priority order:
    1. Approved
    2. Pending Review
    3. Rejected
    4. All other statuses
    """
    # Find all duplicates
    duplicates_mask = df_diff.duplicated(subset='QT:Quote ID', keep=False)
    
    # Get all duplicate rows
    duplicate_rows = df_diff[duplicates_mask].copy()
    
    if duplicate_rows.empty:
        return df_diff
    
    print(f"Found {len(duplicate_rows)} duplicate quote rows to process with priority mapping")
    
    # Define priority mapping for Doc Review Status Text
    priority_order = {
        'Approved': 1,
        'Pending Review': 2,
        'Rejected': 3
    }
    
    # For each duplicate quote ID, apply priority logic
    processed_rows = []
    
    for quote_id in duplicate_rows['QT:Quote ID'].unique():
        # Get all rows for this quote ID
        quote_duplicates = duplicate_rows[duplicate_rows['QT:Quote ID'] == quote_id].copy()
        
        # Add priority column based on Doc Review Status Text
        quote_duplicates['priority'] = quote_duplicates['Doc Review Status Text'].map(priority_order).fillna(999)
        
        # Sort by priority (lower number = higher priority)
        quote_duplicates = quote_duplicates.sort_values('priority')
        
        # Keep the first row (highest priority)
        selected_row = quote_duplicates.iloc[0:1].copy()
        processed_rows.append(selected_row)
    
    if processed_rows:
        processed_df = pd.concat(processed_rows, ignore_index=True)
        
        # Remove all original duplicate rows
        df_diff = df_diff[~duplicates_mask]
        
        # Add back the processed rows (highest priority for each quote ID)
        df_diff = pd.concat([df_diff, processed_df], ignore_index=True)
        
        print(f"Processed {len(processed_df)} duplicate quotes with priority mapping")
    
    return df_diff

